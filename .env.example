# Copy this to .env and fill in your values
# Then: source .env before running the servers

# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional — defaults shown
# WHISPER_MODEL: tiny | base | small | medium | large-v3
WHISPER_MODEL=base
# WHISPER_DEVICE: cpu | cuda
WHISPER_DEVICE=cpu
# STT: lower = faster (1 = default, 5 = slower/more accurate)
# WHISPER_BEAM_SIZE=1
CLAUDE_MODEL=claude-haiku-4-5
HOST=0.0.0.0
PORT=8765
STATIC_PORT=8080
# Interview API (control plane)
INTERVIEW_PORT=8000
# Postgres + Redis (CRM backend + queue)
DATABASE_URL=postgresql+psycopg://crm_user:crm_pass@localhost:5432/crm_db
REDIS_URL=redis://localhost:6379/0
WEBHOOK_SECRET=change-this-webhook-secret
JWT_SECRET=change-this-jwt-secret
CRM_ADMIN_USERNAME=admin
CRM_ADMIN_PASSWORD=admin123
ENFORCE_MIGRATIONS=false
RECORDING_ACCESS_ROLES=admin,manager,qa
# Messaging providers
WHATSAPP_PROVIDER=meta
SMS_PROVIDER=twilio
EMAIL_PROVIDER=ses
# Twilio (optional, needed for real SMS send)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# CORS: comma-separated origins for the interview API
# INTERVIEW_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# Public hints for /v1/integrations (override in production / Docker)
# VOICE_WS_PUBLIC_URL=ws://localhost:8765
# VOICE_HTTP_PUBLIC_URL=http://localhost:8080
# Optional: voice websocket can emit webhook into CRM API automatically
# INTERVIEW_WEBHOOK_URL=http://localhost:8000/v1/calls/webhook
# Optional recording storage path for voice turn mp3 files
# VOICE_RECORDINGS_DIR=services/voice/recordings
BOT_SYSTEM_PROMPT="You are a helpful, concise voice assistant. Keep replies short and natural — they will be spoken aloud. Avoid markdown, bullet points, or long lists."
